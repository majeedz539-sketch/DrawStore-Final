# إعدادات البيئة - انسخ هذا الملف إلى .env وعدّل القيم

# البيئة (development أو production)
FLASK_ENV=development

# تفعيل وضع التصحيح
FLASK_DEBUG=1

# رقم البورت
PORT=5000

# عنوان الاستماع
HOST=0.0.0.0

# مفتاح سري للجلسات
SECRET_KEY=your-super-secret-key-change-this

# إعدادات إضافية
MAX_CONTENT_LENGTH=16777216  # 16MB حد أقصى لحجم الملف
PERMANENT_SESSION_LIFETIME=86400  # مدة الجلسة بالثواني
