{
  "api_documentation": "DrawStore License Verification API",
  "base_url": "https://deaw-production.up.railway.app/api",
  
  "endpoints": {
    
    "verify_license": {
      "path": "/verify-license",
      "method": "POST",
      "description": "التحقق من صحة المفتاح والحصول على الملفات المتاحة",
      "request_body": {
        "key": "string - license key"
      },
      "response_success": {
        "valid": true,
        "files": ["Bo7.exe", "MW3V1.exe", "OW2.exe"]
      },
      "response_error": {
        "valid": false,
        "files": []
      }
    },
    
    "get_files": {
      "path": "/get-files",
      "method": "POST",
      "description": "الحصول على قائمة الملفات المتاحة للمستخدم",
      "request_body": {
        "key": "string - license key"
      },
      "response_success": {
        "files": ["Bo7.exe", "MW3V1.exe"]
      }
    }
  },
  
  "license_database_example": [
    {
      "id": 1,
      "key": "LICENSE-KEY-123456",
      "valid": true,
      "user_id": "user123",
      "user_email": "user@example.com",
      "purchased_files": ["Bo7", "MW3V1"],
      "expiry_date": "2025-12-31",
      "created_at": "2024-01-01",
      "last_used": "2024-04-22"
    },
    {
      "id": 2,
      "key": "LICENSE-KEY-654321",
      "valid": false,
      "user_id": "user456",
      "user_email": "another@example.com",
      "purchased_files": ["OW2"],
      "expiry_date": "2024-03-31",
      "created_at": "2024-01-01",
      "last_used": "2024-03-20"
    }
  ],
  
  "implementation_notes": {
    "1_security": "تأكد من التحقق من المفتاح في كل طلب",
    "2_validation": "تحقق من تاريخ انتهاء الصلاحية",
    "3_logging": "سجل جميع محاولات التحقق",
    "4_rate_limiting": "أضف حد أقصى للطلبات من نفس IP",
    "5_cache": "قد تفكر في تخزين مؤقت للنتائج"
  }
}
